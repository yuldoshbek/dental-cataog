# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Auth (ОБЯЗАТЕЛЬНО сменить в production!) ─────────────────────────────────
# Генерация: openssl rand -hex 32
JWT_SECRET=change_me_to_random_32_char_string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# ── CORS ─────────────────────────────────────────────────────────────────────
# Домен фронтенда. Если на том же сервере — оставить пустым.
CORS_ORIGIN=

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Только цифры (без +): 79001234567
WHATSAPP_MANAGER_PHONE=

# ── Files ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_PRODUCT=8

# ── Catalog Provider ──────────────────────────────────────────────────────────
# 'local' = SQLite база (по умолчанию)
# 'bitrix' = данные из Bitrix24 смарт-процесса (только чтение)
CATALOG_PROVIDER=local

# ── Bitrix24 интеграция (только при CATALOG_PROVIDER=bitrix) ──────────────────
# URL входящего вебхука: Настройки → Интеграции → Входящие вебхуки
BITRIX_WEBHOOK_URL=

# entityTypeId смарт-процесса (число из URL при просмотре смарт-процесса)
BITRIX_SMART_PROCESS_ENTITY_TYPE_ID=

# Кэш данных Bitrix в мс (по умолчанию 60000 = 1 минута)
BITRIX_CACHE_TTL_MS=60000

# Маппинг полей — только если коды полей отличаются от стандартных
# Пример: BITRIX_FIELD_MAP_JSON={"brand":"ufCrm5Brand","model":"ufCrm5Model"}
BITRIX_FIELD_MAP_JSON=

# Маппинг категорий — если в Bitrix хранятся русские названия
# Пример: BITRIX_CATEGORY_MAP_JSON={"Установки":"units","Компрессоры":"compressors"}
BITRIX_CATEGORY_MAP_JSON=

# Маппинг стадий — переопределение логики статусов
# Пример: BITRIX_STAGE_MAP_JSON={"DT1234_1:SUCCESS":"published"}
BITRIX_STAGE_MAP_JSON=
