# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Auth (ОБЯЗАТЕЛЬНО сменить!) ───────────────────────────────────────────────
# Генерация: openssl rand -hex 32
JWT_SECRET=change_me_to_random_32_char_string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# ── CORS ─────────────────────────────────────────────────────────────────────
# Домен фронтенда. Если на том же сервере — оставить пустым (nginx проксирует).
CORS_ORIGIN=

# ── Files ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_PRODUCT=8

# ── Catalog Provider ──────────────────────────────────────────────────────────
# 'local'  = SQLite база (по умолчанию, CRUD через AdminPage)
# 'bitrix' = данные из Bitrix24 смарт-процесса (только чтение, CRUD блокируется)
CATALOG_PROVIDER=local

# ── Bitrix24 интеграция ────────────────────────────────────────────────────────
# Заполнить и переключить CATALOG_PROVIDER=bitrix для работы с Bitrix.
#
# Смарт-процесс: «Каталог оборудования»
#   Домен:         3dexpert.bitrix24.ru
#   SP ID:         35
#   entityTypeId:  1106
#
# Вебхук:
#   Bitrix24 → Настройки → Интеграции → Входящие вебхуки → создать/скопировать
#   Формат: https://3dexpert.bitrix24.ru/rest/{userId}/{token}/
BITRIX_WEBHOOK_URL=https://3dexpert.bitrix24.ru/rest/22473/<ВСТАВИТЬ_ТОКЕН>/

# entityTypeId смарт-процесса (прошит в коде как 1106, но можно переопределить)
BITRIX_SMART_PROCESS_ENTITY_TYPE_ID=1106

# Кэш данных из Bitrix (мс). По умолчанию 60 секунд.
# Увеличить до 300000 (5 мин) в prod, уменьшить до 5000 (5 сек) при отладке.
BITRIX_CACHE_TTL_MS=60000

# ── Bitrix override (обычно не нужно, маппинги прошиты в bitrixConfig.js) ──────
# Переопределить отдельные поля, если изменились коды в Bitrix.
# Пример: BITRIX_FIELD_MAP_JSON={"brand":"UF_CRM_35_NEW_CODE"}
BITRIX_FIELD_MAP_JSON=

# Переопределить маппинг категорий (enum ID → внутренний id).
# По умолчанию: {"1229":"units","1231":"compressors",...} — прошито в коде.
BITRIX_CATEGORY_MAP_JSON=

# Переопределить маппинг стадий.
# По умолчанию: {"DT1106_57:SUCCESS":"published",...} — прошито в коде.
BITRIX_STAGE_MAP_JSON=
