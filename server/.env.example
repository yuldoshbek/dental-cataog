# -- Server -------------------------------
PORT=3001
NODE_ENV=production

# -- Catalog Provider ---------------------
# local  = Express + SQLite
# bitrix = Bitrix smart-process as single source of truth
CATALOG_PROVIDER=local

# -- Security -----------------------------
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=8h

# -- Admin Credentials (change before deploy!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SuperSecret123!

# -- WhatsApp -----------------------------
# Номер менеджера (только цифры, без +): 7XXXXXXXXXX
WHATSAPP_MANAGER_PHONE=7XXXXXXXXXX

# -- CORS ---------------------------------
# Укажите ваш домен (без слеша в конце)
CORS_ORIGIN=https://yourdomain.com

# -- Upload -------------------------------
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_PRODUCT=8

# -- Bitrix Smart Process -----------------
# Пример: https://your-company.bitrix24.ru/rest/1/xxxxxxxxxxxx
BITRIX_WEBHOOK_URL=
# Пример: 1036
BITRIX_SMART_PROCESS_ENTITY_TYPE_ID=
# TTL кеша каталога в миллисекундах
BITRIX_CACHE_TTL_MS=60000
# JSON mapping полей Bitrix -> normalized catalog contract
BITRIX_FIELD_MAP_JSON={"categoryId":"ufCrmCategory","brand":"ufCrmBrand","model":"ufCrmModel","country":"ufCrmCountry","priceLabel":"ufCrmPriceLabel","priceMin":"ufCrmPriceMin","priceAvg":"ufCrmPriceAvg","priceMax":"ufCrmPriceMax","description":"ufCrmManagerDescription","clientDescription":"ufCrmClientDescription","specs":"ufCrmSpecs","colors":"ufCrmColors","upholstery":"ufCrmUpholstery","baseConfig":"ufCrmBaseConfig","options":"ufCrmOptions","forUnits":"ufCrmForUnits","dryer":"ufCrmDryer","cover":"ufCrmCover","type":"ufCrmType","cylinders":"ufCrmCylinders","dimensions":"ufCrmDimensions","primaryImage":"ufCrmPrimaryImage","gallery":"ufCrmGallery","shareSlug":"ufCrmShareSlug","externalCode":"ufCrmExternalCode","isActive":"ufCrmIsActive","publishWeb":"ufCrmPublishWeb","publishShare":"ufCrmPublishShare","publishTelegram":"ufCrmPublishTelegram"}
# JSON map значения поля категории -> локальный id категории
BITRIX_CATEGORY_MAP_JSON={"Установки":"units","Компрессоры":"compressors","Автоклавы":"autoclaves","Физиодиспенсеры":"physio","Интраоральные сканеры":"scanners","Рентгены портативные":"xray","Визиографы":"visiographs","Наконечники":"handpieces"}
# JSON map StageId Bitrix -> normalized status
BITRIX_STAGE_MAP_JSON={"NEW":"draft","PREPARATION":"review","CLIENT":"ready_internal","SUCCESS":"published","FAIL":"archived"}
