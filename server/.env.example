# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Auth (ОБЯЗАТЕЛЬНО сменить в production!) ─────────────────────────────────
# Генерация: openssl rand -hex 32
JWT_SECRET=change_me_to_random_32_char_string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# ── CORS ─────────────────────────────────────────────────────────────────────
# Домен фронтенда. Если на том же сервере — оставить пустым.
CORS_ORIGIN=

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Только цифры (без +): 79001234567
WHATSAPP_MANAGER_PHONE=

# ── Files ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
