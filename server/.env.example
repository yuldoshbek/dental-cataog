# ── Server ──────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ─────────────────────────────────
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=8h

# ── Admin Credentials (change before deploy!) ─
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SuperSecret123!

# ── WhatsApp ─────────────────────────────────
# Номер менеджера (только цифры, без +): 7XXXXXXXXXX
WHATSAPP_MANAGER_PHONE=7XXXXXXXXXX

# ── CORS ─────────────────────────────────────
# Укажите ваш домен (без слэша в конце)
CORS_ORIGIN=https://yourdomain.com

# ── Upload ───────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_PRODUCT=8
